{
  "name": "vex-core",
  "version": "0.3.9",
  "description": "Local-first reactive backend engine. Plugin architecture, SQLite + DuckDB storage, real-time subscriptions.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "default": "./dist/client/index.js"
    },
    "./http": {
      "types": "./dist/http/index.d.ts",
      "import": "./dist/http/index.js",
      "default": "./dist/http/index.js"
    },
    "./framework": {
      "types": "./dist/framework/index.d.ts",
      "import": "./dist/framework/index.js",
      "default": "./dist/framework/index.js"
    },
    "./adapters/sqlite": {
      "types": "./dist/adapters/sqlite.d.ts",
      "import": "./dist/adapters/sqlite.js",
      "default": "./dist/adapters/sqlite.js"
    },
    "./adapters/duckdb": {
      "types": "./dist/adapters/duckdb.d.ts",
      "import": "./dist/adapters/duckdb.js",
      "default": "./dist/adapters/duckdb.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "format": "bunx biome format --write src/",
    "lint": "bunx biome lint src/",
    "check": "bunx biome check src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run typecheck && bun run build"
  },
  "keywords": [
    "database",
    "reactive",
    "sqlite",
    "duckdb",
    "local-first",
    "convex",
    "plugin",
    "backend"
  ],
  "license": "MIT",
  "author": "Michael Liv",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Michaelliv/vex-core.git"
  },
  "bugs": {
    "url": "https://github.com/Michaelliv/vex-core/issues"
  },
  "homepage": "https://github.com/Michaelliv/vex-core#readme",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@types/bun": "^1.2.17",
    "@types/react": "^19.2.14",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@duckdb/node-api": "^1.5.2-r.1",
    "nanoid": "^5.1.7"
  },
  "peerDependencies": {
    "react": "^19.2.4"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
