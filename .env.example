# Required — platform auth key
VEX_KEY=

# Span retention (default: 7d)
# VEX_SPAN_RETENTION=7d

# Lifecycle event retention (default: 30d)
# VEX_EVENT_RETENTION=30d

# Query/mutation handler timeout (default: 30s)
# VEX_HANDLER_TIMEOUT=30s

# Trace sampling rate 0.0-1.0 (default: 1.0)
# VEX_TRACE_SAMPLE_RATE=1.0

# CORS origin (default: *)
# VEX_CORS_ORIGIN=*

# Bun idle timeout in seconds (default: 255)
# VEX_IDLE_TIMEOUT=255
